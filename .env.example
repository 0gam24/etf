# ───────────────────────────────
# Daily ETF Pulse — 환경변수 템플릿
# 복사: cp .env.example .env.local
# ───────────────────────────────

# === 데이터 소스 ===

# 공공데이터포털 — ETF 시세 (필수)
# https://www.data.go.kr → "금융위원회_증권상품시세정보" 활용신청 → 일반 인증키(Encoding)
DATA_GO_KR_API_KEY=

# 한국은행 ECOS — 경제지표 (필수)
# https://ecos.bok.or.kr/api/ → 인증키 신청
BOK_ECOS_API_KEY=

# === AI ===

# Google Gemini 2.5 Flash — 본문 작성 + Vision OCR + 뉴스 요약
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# === 뉴스 — 네이버 검색 API (선택) ===
#
# 설정하면 NewsCollector가 Google News RSS + Naver News를 **병렬 수집**하고
# 중복 제거해 병합합니다. 한국 언론사 커버리지·스니펫 품질이 크게 개선됩니다.
# 미설정 시 자동 스킵 — Google News RSS만 사용 (정상 동작).
#
# 발급 (무료 · 일 25,000건):
#   1. https://developers.naver.com 로그인 → "Application" → 등록
#   2. 사용 API에서 "검색" 체크 · 환경은 WEB 추가 (URL은 http://localhost:3000 OK)
#   3. 등록 완료 직후 상세 화면에 Client ID · Client Secret 표시 → 아래에 붙여넣기
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# === MARKET PULSE 이미지 (Daily ETF Pulse 핵심) ===

# 매일 갱신되는 MARKET PULSE 이미지의 직접 URL
# 이 URL이 있으면 DataMiner가 자동 다운로드 + Gemini Vision으로 OCR 수행
PULSE_IMAGE_URL=

# === 사이트 ===

# 배포 도메인 (sitemap.xml · RSS · Indexing에 사용)
SITE_URL=https://iknowhowinfo.com

# === 한국투자증권 OpenAPI (장중 분단위 실시간 시세 · 선택) ===
# 빈 계좌면 보안 위험 최소화 (매매 권한 X). 미등록 시 자동 mock 모드 → /api/etf/realtime 가 polling fallback.
# 발급:
#   1. https://apiportal.koreainvestment.com 회원가입 (한투 계좌 ID 로 로그인)
#   2. "API 신청/발급" → 실전·모의 둘 다 신청 (시세 조회는 무료, 즉시 발급)
#   3. APP_KEY · APP_SECRET 발급 직후 1회만 노출 — 즉시 저장
#   4. KIS_MODE: production | sandbox | mock (기본 production)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_MODE=production

# === Google Indexing API (Phase 5) ===

# 서비스 계정 JSON 파일 전체 문자열을 JSON 인코딩해서 넣거나, 파일 경로를 INDEXING_KEY_FILE에 넣어도 됨
GOOGLE_INDEXING_KEY=
GOOGLE_INDEXING_KEY_FILE=

# === 색인 요청 (Bing IndexNow — 구글 Indexing API는 일반 블로그 미지원) ===

# Bing IndexNow 키 (32자 hex 추천). 빌드 시 public/{key}.txt 자동 생성
# 발급: 아무 32자 hex 생성해도 됨. 예: openssl rand -hex 16
INDEXNOW_KEY=

# === Threads 자동 포스팅 (하루 2회: 오전 pulse + 오후 flow/income) ===

# Meta Threads API (무료)
# 발급: https://developers.facebook.com → Threads API → User Access Token
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# === 스케줄러 ===
# KST 기준 시각 (기본 08:30)
PULSE_SCHEDULE_HOUR=8
PULSE_SCHEDULE_MINUTE=30

# === 제휴 URL (실제 제휴 승인 후 채우기) ===
# 없으면 6_cpa_deal_maker.js가 "#" placeholder 사용

AFFILIATE_URL_MIRAE=
AFFILIATE_URL_KB=
AFFILIATE_URL_TOSS=
AFFILIATE_URL_SAMSUNG=
AFFILIATE_URL_NH=
AFFILIATE_URL_SHINHAN=
AFFILIATE_URL_HANA=

# === Coupang Partners Open API ===
# 최종승인(누적 매출 15만원) 후 partners.coupang.com 에서 발급
# 빌드/cron 시점에만 사용 (Cloudflare 런타임에 절대 노출 X)
# scripts/fetch-products.mjs 가 데일리 cron으로 자동 갱신
COUPANG_PARTNERS_ACCESS_KEY=
COUPANG_PARTNERS_SECRET_KEY=
AFFILIATE_URL_NH_IRP=
AFFILIATE_URL_MIRAE_ISA=
AFFILIATE_URL_KB_PENSION=
AFFILIATE_URL_BOOK_THEME=
AFFILIATE_URL_BOOK_FLOW=
AFFILIATE_URL_BOOK_DIV=
